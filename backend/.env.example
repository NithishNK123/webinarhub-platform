# APP SETTINGS
NODE_ENV=development
PORT=5000

# DATABASE (Postgres inside Docker Compose)
DATABASE_URL=postgresql://webinar:securepassword@localhost:5432/webinarhub?schema=public

# REDIS CONNECTION
REDIS_URL=redis://localhost:6379

# AUTHENTICATION SECRETS
JWT_SECRET=super_secret_jwt_key_replace_me
JWT_REFRESH_SECRET=super_secret_refresh_key_replace_me
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# PAYMENT GATEWAY (Razorpay)
RAZORPAY_KEY_ID=rzp_test_YourKeyIdHere
RAZORPAY_KEY_SECRET=YourSecretKeyHere
RAZORPAY_WEBHOOK_SECRET=YourWebhookSecretHere
